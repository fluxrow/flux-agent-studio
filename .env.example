# =============================================================================
# FluxBot — Environment variables (EXAMPLE)
# =============================================================================
# O arquivo .env REAL é gerado/atualizado automaticamente pelo Lovable Cloud.
# NÃO edite .env manualmente. Use este arquivo apenas como referência.
# =============================================================================

# ---- Lovable Cloud (Supabase) — públicas/publishable ------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
VITE_SUPABASE_PROJECT_ID=your-project-ref

# ---- Feature flags ----------------------------------------------------------
# Flipa toda a camada de persistência entre mocks (false) e Supabase (true).
VITE_USE_SUPABASE=true

# ---- Segredos privados (NUNCA versionar) ------------------------------------
# Segredos reais ficam em Lovable Cloud → Secrets ou em Edge Functions.
# Exemplos (NÃO usar VITE_* para qualquer coisa sensível):
#
#   OPENAI_API_KEY=
#   STRIPE_SECRET_KEY=
#   META_APP_SECRET=
#   GOOGLE_OAUTH_CLIENT_SECRET=
